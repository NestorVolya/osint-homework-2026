# Node.js (shell build artifacts are copied, not source node_modules)
packages/arkham-shard-shell/node_modules/

# Documentation
docs/
*.md
!README.md

# Test files
tests/
**/tests/
**/*_test.py
**/test_*.py

# Config examples (actual config is mounted)
.env
.env.*
!.env.example

# Docker
Dockerfile*
docker-compose*.yml
!docker-compose.yml
.docker/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Temporary files
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# Data directories (mounted as volumes, not copied)
DataSilo/
data/
uploads/
exports/

# Claude/AI
.claude/
CLAUDE.md

# Build artifacts we don't need in container
*.tar
*.tar.gz
*.zip
